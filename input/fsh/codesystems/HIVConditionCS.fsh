CodeSystem: HIVConditionCS
Id: hiv-condition-cs
Title: "HIV Condition Code System"
Description: "Clinical HIV-related conditions and diagnoses"

* insert CSMeta
* ^status = #active
* ^content = #complete

* #hiv-positive "HIV Positive"
  "Confirmed HIV infection"

* #hiv-negative "HIV Negative"
  "Confirmed HIV negative status"

* #hiv-exposed "HIV Exposed"
  "Person exposed to HIV"

* #acute-hiv-infection "Acute HIV Infection"
  "Acute or primary HIV infection"

* #advanced-hiv-disease "Advanced HIV Disease"
  "Advanced HIV disease according to WHO criteria"

* #aids "AIDS"
  "Acquired Immunodeficiency Syndrome"

* #art-eligible "Eligible for ART"
  "Client meets criteria for ART initiation"

* #on-art "On ART"
  "Client currently receiving antiretroviral therapy"

* #art-interrupted "ART Interrupted"
  "ART treatment interrupted"

* #lost-to-followup "Lost to Follow-up"
  "Client missed care and follow-up requirements"

* #transferred-in "Transferred In"
  "Client transferred from another facility"

* #transferred-out "Transferred Out"
  "Client transferred to another facility"

* #deceased "Deceased"
  "Client died"

* #unknown-status "Unknown HIV Status"
  "HIV status is not known"